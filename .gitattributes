# Normalize line endings so the repo stops churning between LF and CRLF.
# Text files are stored as LF in the repository and checked out per-platform.
* text=auto

# Windows batch launchers must stay CRLF to run correctly.
*.bat text eol=crlf

# Treat generated/office and image assets as binary (never line-ending converted).
*.docx binary
*.xlsx binary
*.xlsm binary
*.pptx binary
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.zip  binary
*.ico  binary
